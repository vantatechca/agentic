# ─────────────────────────────────────────────────────────────────────────────
# Agentic (EngageOS) — environment configuration
# Copy to `.env` and fill in. Values marked (P1) are needed for Phase 1.
# The app boots without optional keys; features that need a missing key
# degrade to a stub/manual-refresh mode rather than crashing.
# ─────────────────────────────────────────────────────────────────────────────

# --- App ---------------------------------------------------------------------
# Product display name lives in code (src/config/app.ts) but can be overridden.
NEXT_PUBLIC_APP_NAME=Agentic
# Simple shared-secret gate for admin API routes (P1; replace with real auth later)
ADMIN_API_TOKEN=change-me-in-prod

# --- Database (Neon Postgres) ------------------------------------------- (P1)
DATABASE_URL=postgres://user:password@host.neon.tech/agentic?sslmode=require

# --- Redis (Upstash) for BullMQ ----------------------------------------- (P1)
# Use the rediss:// TLS URL from Upstash. BullMQ connects via ioredis.
REDIS_URL=rediss://default:password@host.upstash.io:6379

# --- AI providers (DeepSeek primary -> Claude Sonnet fallback) ---------- (P1)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Discord webhooks --------------------------------------------------- (P1)
# One base is enough; per-niche channels can be configured in the admin UI/DB.
# These are fallback/global webhooks used when a niche has no channel override.
DISCORD_WEBHOOK_ALERTS=
DISCORD_WEBHOOK_TRENDS=
DISCORD_WEBHOOK_FLEET_HEALTH=

# --- Inngest (crons/events) --------------------------------------------- (P2)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- YouTube Data API (P2 monitoring / P3 posting / P4 commenting) -----------
YOUTUBE_API_KEY=

# --- Instagram Graph API (P3 posting) ----------------------------------------
IG_GRAPH_API_TOKEN=

# --- TikTok Content Posting API (P3 posting) ---------------------------------
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# --- Scraper adapters (P2; free-scrape best-effort, Apify swap-in later) ------
# When empty, IG/TikTok monitoring runs in manual-refresh fallback mode.
APIFY_TOKEN=
